# Copy to .env.prod and fill in real values before running docker-compose.prod.yml
#
# Generate secrets with: openssl rand -base64 64
#
# IMPORTANT: the db hostname is "db" (the Docker service name), not "localhost"

DATABASE_URL=postgresql://mhuser:mhpass@db:5432/mh_datapedia
JWT_SECRET=<run: openssl rand -base64 64>
JWT_REFRESH_SECRET=<run: openssl rand -base64 64>
PORT=3001
NODE_ENV=production
CORS_ORIGIN=http://localhost
